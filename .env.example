# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PUBLIC_APP_URL=http://localhost:5173
API_URL=http://localhost:3001
DB_REQUESTS_PER_SECOND=10
API_BASE_URL=http://localhost:3001
PORT=3001

# ─── Database (PostgreSQL) ───────────────────────────
# Database name: proofloop — run: npm run db:setup
DATABASE_URL=postgresql://postgres:password@localhost:5432/proofloop
DB_URL=jdbc:postgresql://localhost:5432/proofloop
DB_USERNAME=postgres
DB_PASSWORD=
JWT_SECRET=

# ─── AI / Embeddings ─────────────────────────────────
VOYAGE_API_KEY=
OPENAI_API_KEY=
AI_DEMO_MODE=true

# ─── Search ──────────────────────────────────────────
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=proofloop-typesense-key

# ─── Observability ───────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
GRAFANA_URL=http://localhost:3000

# ─── Sponsor Integrations (team keys — copy to .env; do not use in production) ──────
