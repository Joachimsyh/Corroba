# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PUBLIC_APP_URL=http://localhost:5173
API_URL=http://localhost:3001
DB_REQUESTS_PER_SECOND=10
API_BASE_URL=http://localhost:3001
PORT=3001

# ─── Database ────────────────────────────────────────
DATABASE_URL="postgresql://postgres:220306@localhost:5432/proofloopAI"

# ─── AI / Embeddings ─────────────────────────────────
VOYAGE_API_KEY=
OPENAI_API_KEY=
AI_DEMO_MODE=true

# ─── Search ──────────────────────────────────────────
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=proofloop-typesense-key

# ─── Observability ───────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
GRAFANA_URL=http://localhost:3000

# ─── Sponsor Integrations (add keys when ready) ──────
# Unify GTM — Warm Outbound platform. TWO separate APIs (do not mix the keys):
#  1) Data API  (server-side, SECRET): base https://api.unifygtm.com/data/v1, header X-Api-Key
#  2) Analytics API (intent events):   base https://api.unifyintent.com/analytics/v1, header X-Write-Key
# WARNING: never send the secret Data API key to the Analytics API — Unify expires it.
# The write key is safe to expose; get it from Unify → Settings → Web & product data.
UNIFY_API_KEY=
UNIFY_API_URL=https://api.unifygtm.com/data/v1
UNIFY_WRITE_KEY=
UNIFY_ANALYTICS_URL=https://api.unifyintent.com/analytics/v1
UNIFY_ANALYTICS_ORIGIN=http://localhost:5173

# GTMengineer.dev — GTM System Generator (simulated internally)
GTMENGINEER_API_KEY=
GTMENGINEER_API_URL=

# Faxxing — Proof Amplification Engine
FAXXING_API_KEY=
FAXXING_API_URL=

# Zero — Proof CRM (set ZERO_API_KEY in your local .env — never commit it)
ZERO_API_KEY=
ZERO_API_URL=https://zero.inc
ZERO_API_RECORDS_PATH=/corroba/records

# Lightfern — Proof Validation Engine
LIGHTFERN_API_KEY=
LIGHTFERN_API_URL=

# Scaile — Growth Recommendation Engine
SCAILE_API_KEY=
SCAILE_API_URL=
